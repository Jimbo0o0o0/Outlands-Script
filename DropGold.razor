@setvar! golddamount 2000
while weight > maxweight
    if findtype 8198 ground -1 -1 2 as corpse
        @drop backpack
        lifttype 'gold coin' golddamount
        drop corpse
        wait 500
    elseif findtype 'gold coin' ground -1 -1 2 as GroundCoin
        @drop backpack
        lifttype 'gold coin' golddamount
        drop Groundcoin
        wait 500
    else
        @drop backpack
        lifttype 'gold coin' golddamount
        droprelloc 0 0
        wait 500
    endif
endwhile