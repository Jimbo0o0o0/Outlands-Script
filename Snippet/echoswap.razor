#Change EchoName
yell [echo
wait 200
while not ingump 'EchoName'
    waitforgump 210712595
    gumpresponse 8
    wait 300
endwhile
clearsysmsg
waitforgump 210712595
gumpresponse 6
wait 300
if insysmsg 'You have recently been in combat and must wait'
    overhead 'Calm Down... Recently in combat and must wait' 38
    waitforgump 210712595
    gumpclose
elseif ingump 'Next Activation Allowed in'
    overhead 'You cannot change now, must wait or buy customizations.' 44
    waitforgump 210712595
    gumpclose
elseif insysmsg 'Click once more to confirm activation of this echo.'
    waitforgump 210712595
    gumpresponse 6
    waitforgump 210712595
    gumpclose
    overhead 'EchoName Activated!' 68
endif

#Change Profile Shelf number (#NumberYouWantHere)
if skill 'SkillYourEchoHave' = 100
    if findtype 'storage shelf' ground -1 -1 2  as Shelf
        wait 200
        gumpclose
        wait 200
        dclick Shelf
        while not ingump '(NumberItemYourRightProfileHave Items)'
            gumpresponse 18
            waitforgump 3232825965
        endwhile
        wait 200
        menu Shelf 1
        waitforgump 3232825965
        gumpclose
        overhead 'Resupply Complete' 68
    else
        overhead 'Shelf Not Found, Maybe to Far of it' 38
    endif
else
    overhead 'No skill match for this echo or profile' 38
endif